# Salin file ini menjadi bot/.env lalu isi nilainya. JANGAN commit bot/.env.
BOT_TOKEN=                       # dari @BotFather
STORAGE_CHANNEL_ID=              # channel privat; bot HARUS admin (format: -100xxxxxxxxxx)
OWNER_USER_ID=                   # user id Telegram-mu (pembatas akses + tujuan warning)
TURSO_DATABASE_URL=              # libsql://...turso.io
TURSO_AUTH_TOKEN=                # token dari `turso db tokens create <db>`

# Worker (Telethon) — dipakai di milestone berikutnya
TG_API_ID=
TG_API_HASH=

# Worker/watcher (opsional)
SEVENZIP_PATH=                   # path 7z.exe bila tidak di PATH, mis. C:\Program Files\7-Zip\7z.exe
WORKER_OUT_DIR=                  # folder output split (default: %TEMP%\tcd_upload_parts)
WORKER_SESSION=worker            # nama file .session
