# Copy this file to bot/.env and fill in the values. DO NOT commit bot/.env.
BOT_TOKEN=                       # from @BotFather
STORAGE_CHANNEL_ID=              # private channel; bot MUST be admin (format: -100xxxxxxxxxx)
OWNER_USER_ID=                   # your Telegram user id (access control + warning destination)
TURSO_DATABASE_URL=              # libsql://...turso.io
TURSO_AUTH_TOKEN=                # token from `turso db tokens create <db>`

TG_API_ID=
TG_API_HASH=

SEVENZIP_PATH=                   # path to 7z.exe if not in PATH, e.g. C:\Program Files\7-Zip\7z.exe
WORKER_OUT_DIR=                  # split output folder (default: %TEMP%\tcd_upload_parts)
WORKER_SESSION=worker            # .session filename
