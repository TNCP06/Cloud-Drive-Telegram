# Copy to `.env` (used by docker-compose for all three services). DO NOT commit.

# ── Telegram ────────────────────────────────────────────────────────────────
BOT_TOKEN=                  # @BotFather token (bot.py + web purge/thumbnail)
TG_API_ID=                  # my.telegram.org (watcher / Telethon)
TG_API_HASH=                # my.telegram.org (watcher / Telethon)
STORAGE_CHANNEL_ID=         # private channel id, e.g. -1001234567890 (bot must be admin)
OWNER_USER_ID=              # your Telegram user id (download + Bot Drop allowlist)
NEXT_PUBLIC_BOT_USERNAME=   # bot username WITHOUT @ (inlined into web at build time)
TELEGRAM_API_URL=           # Optional local Bot API server endpoint (e.g. http://telegram-bot-api:8081 for Docker)


# ── Turso (libSQL) ──────────────────────────────────────────────────────────
TURSO_DATABASE_URL=         # libsql://... (rewritten to https:// automatically)
TURSO_AUTH_TOKEN=

# ── Web auth ────────────────────────────────────────────────────────────────
APP_PASSWORD=               # shared dashboard password; leave empty to disable auth

# ── Watcher (optional) ──────────────────────────────────────────────────────
WORKER_SESSION=worker       # Telethon session name → bot/worker.session
# UPLOAD_STAGING_DIR / WORKER_OUT_DIR are set by docker-compose (/staging). Only set
# them here if you run the processes WITHOUT Docker and need web+watcher to agree on
# the same shared folder.

# ── Streamer (video streaming, optional) ────────────────────────────────────
STREAMER_SESSION=streamer   # Telethon session name → bot/streamer.session
# CACHE_DIR, CACHE_MAX_SIZE_GB, PREFETCH_BUFFER_MB, CHUNK_SIZE_MB, INITIAL_CHUNKS,
# PREFETCH_TIMEOUT_S, STREAMER_PORT are set by docker-compose. Only override here
# if running WITHOUT Docker.

# ── Background video compression (optional; defaults set by docker-compose) ──
# First view streams the ORIGINAL (instant); a background ffmpeg job writes a smaller
# H.264 copy to the PERSISTENT /compressed volume → later views serve the compressed one.
# VIDEO_COMPRESS=1                 # set 0 to disable
# VIDEO_CRF=23                     # 18=near-lossless … 28=smaller
# VIDEO_PRESET=medium              # ffmpeg x264 speed/size tradeoff
# VIDEO_MIN_COMPRESS_MB=20         # skip files smaller than this
# VIDEO_TRANSCODE_CONCURRENCY=1    # parallel ffmpeg jobs (CPU-heavy)
# COMPRESSED_MAX_SIZE_GB=0         # 0 = keep forever; >0 = LRU-cap the compressed dir
